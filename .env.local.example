# Privy Auth - get your App ID at https://dashboard.privy.io
# Optional: without it the site runs but Apple/Google sign-in is disabled.
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id-here

# Market data is served by free, key-less public APIs — no keys required:
#   - DexScreener  (https://api.dexscreener.com)   token overview + trending
#   - GeckoTerminal (https://api.geckoterminal.com) OHLCV candles + live trades
# The app uses these out of the box; data is real but rate-limited.

# Solana RPC: the app relies on Privy's default public Solana RPC. No key needed.
