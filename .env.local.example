# Privy Auth - get your App ID at https://dashboard.privy.io
# Optional: without it the site runs but Apple/Google sign-in is disabled.
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id-here

# BirdEye - the single market-data source (token overview, trending, OHLCV
# candles, live swaps). Get your key at https://birdeye.so/data-api
# Without it the app still runs but serves mock market data.
BIRDEYE_API_KEY=your-birdeye-api-key-here

# Solana RPC: the app relies on Privy's default public Solana RPC. No key needed.
